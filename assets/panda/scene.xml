<mujoco model="panda_office">
  <compiler angle="radian" autolimits="true"/>

  <include file="panda.xml"/>

  <asset>
    <!-- Skybox for office lighting ambiance -->
    <texture type="skybox" builtin="gradient" rgb1="0.9 0.9 0.95" rgb2="0.7 0.7 0.7" width="512" height="3072"/>
    
    <!-- Floor texture -->
    <texture type="2d" name="floor_tex" builtin="checker" mark="edge" rgb1="0.5 0.5 0.5" rgb2="0.4 0.4 0.4" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    
    <!-- Materials -->
    <material name="floor_material" texture="floor_tex" texuniform="true" texrepeat="5 5" reflectance="0.1"/>
    <material name="wall_material" rgba="0.8 0.8 0.8 1"/>
    <material name="desk_material" rgba="0.6 0.4 0.2 1"/>
    <material name="obstacle_material" rgba="0.3 0.3 0.3 1"/>
  </asset>

  <worldbody>
    <!-- Lighting setup - two ceiling lights -->
    <light pos="0.3 0 0.9" dir="0 0 -1" diffuse="0.9 0.9 0.9" specular="0.1 0.1 0.1"/>
    <light pos="0.7 0 0.9" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.05 0.05 0.05"/>
    
    <!-- Floor plane -->
    <geom name="floor" type="plane" size="2 2 1" material="floor_material"/>
    
    <!-- Back wall -->
    <body name="wall_back">
      <geom type="box" size="1.5 0.05 0.5" pos="0 -1.5 0.5" material="wall_material"/>
    </body>
    
    <!-- Left wall -->
    <body name="wall_left">
      <geom type="box" size="0.05 1.5 0.5" pos="-1.5 0 0.5" material="wall_material"/>
    </body>
    
    <!-- Right wall -->
    <body name="wall_right">
      <geom type="box" size="0.05 1.5 0.5" pos="1.5 0 0.5" material="wall_material"/>
    </body>
    
    <!-- Desk: centered in workspace -->
    <body name="desk">
      <!-- Desktop -->
      <geom name="desk_surface" type="box" size="0.5 0.3 0.02" pos="0 0.3 0.75" material="desk_material"/>
      <!-- Desk legs -->
      <geom name="desk_leg_1" type="box" size="0.04 0.04 0.35" pos="-0.4 0.1 0.35" material="obstacle_material"/>
      <geom name="desk_leg_2" type="box" size="0.04 0.04 0.35" pos="0.4 0.1 0.35" material="obstacle_material"/>
      <geom name="desk_leg_3" type="box" size="0.04 0.04 0.35" pos="-0.4 0.5 0.35" material="obstacle_material"/>
      <geom name="desk_leg_4" type="box" size="0.04 0.04 0.35" pos="0.4 0.5 0.35" material="obstacle_material"/>
    </body>
    
    <!-- Target object: cup on desk surface -->
    <body name="target" pos="0 0.3 0.78">
      <geom name="target_geom" type="cylinder" size="0.03 0.04" rgba="0.95 0.2 0.2 1"/>
    </body>
    
    <!-- Bookshelf obstacle -->
    <body name="bookshelf">
      <geom type="box" size="0.08 0.2 0.35" pos="1.2 0.5 0.35" material="desk_material"/>
    </body>
    
    <!-- Left cabinet -->
    <body name="cabinet_left">
      <geom type="box" size="0.1 0.15 0.25" pos="-1.2 0.2 0.25" material="obstacle_material"/>
    </body>
    
    <!-- Right monitor stand -->
    <body name="monitor_stand">
      <geom type="box" size="0.1 0.12 0.2" pos="1.2 -0.8 0.2" material="obstacle_material"/>
    </body>
  </worldbody>
</mujoco>
